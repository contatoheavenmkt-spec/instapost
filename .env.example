# Copia esse arquivo pra .env e preenche.
# Não commita o .env real (já está no .gitignore).

# Domínio público apontando pra essa VPS (sem https://)
# Ex: insta.seudominio.com.br
DOMAIN=insta.seudominio.com.br

# Email pro Let's Encrypt avisar quando o certificado for expirar
EMAIL=seu@email.com

# URL base completa usada pra montar os short links nos Stories
# Tem que casar com o DOMAIN acima.
PUBLIC_BASE_URL=https://insta.seudominio.com.br
